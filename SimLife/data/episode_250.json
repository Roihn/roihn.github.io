   "dialogue": {
    "label": "The rule changes: wrist injury",
    "audio": "assets/audio/vc250_pos10.mp3",
    "transcript": [
     {
      "speaker": "Mother Sim",
      "text": "I tweaked my wrist playing piano, so I rest."
     },
     {
      "speaker": "Father Sim",
      "text": "That hurts. You should definitely rest that wrist."
     },
     {
      "speaker": "Mother Sim",
      "text": "I really wanted to play, but it hurts so much."
     },
     {
      "speaker": "Father Sim",
      "text": "Your hands are vital for cooking, so rest them well."
     },
     {
      "speaker": "Mother Sim",
      "text": "Yeah, I guess I need to relax."
     },
     {
      "speaker": "Father Sim",
      "text": "You are strong, and I know you will heal quickly soon. Just focus on resting well and take care."
     },
     {
      "speaker": "Mother Sim",
      "text": "Thanks for saying that, it really helps me feel better."
     },
     {
      "speaker": "Father Sim",
      "text": "Let me know if you need anything to help."
     },
     {
      "speaker": "Mother Sim",
      "text": "I will take care, I promise I will be careful."
     },
     {
      "speaker": "Father Sim",
      "text": "Okay, rest up and I will keep an eye on the situation."
     },
     {
      "speaker": "Mother Sim",
      "text": "That sounds good, I will just relax and do nothing."
     },
     {
      "speaker": "Father Sim",
      "text": "Enjoy your break, and we can chat about piano later."
     },
     {
      "speaker": "Mother Sim",
      "text": "Sounds great, I am ready to just chill out today."
     },
     {
      "speaker": "Father Sim",
      "text": "I love you, and I am here to support you now."
     },
     {
      "speaker": "Mother Sim",
      "text": "Thank you, that means a lot to me right now."
     },
     {
      "speaker": "Father Sim",
      "text": "Just let me know if you need anything else today."
     },
     {
      "speaker": "Mother Sim",
      "text": "Okay, I will stay here and take it easy."
     },
     {
      "speaker": "Father Sim",
      "text": "Okay, I will leave you to rest now then today."
     }
    ]
   },
